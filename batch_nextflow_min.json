{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "NextflowAwsBatchExecutor",
      "Effect": "Allow",
      "Action": [
        "batch:SubmitJob",
        "batch:DescribeJobs",
        "batch:TerminateJob",
        "batch:DescribeJobDefinitions",
        "batch:DescribeJobQueues",
        "batch:DescribeComputeEnvironments"
      ],
      "Resource": "*"
    }
  ]
}
